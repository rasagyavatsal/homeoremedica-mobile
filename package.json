{
  "name": "@homeoremedica/mobile",
  "workspaces": [
    "packages/*"
  ],
  "main": "expo-router/entry",
  "version": "2.9.1",
  "scripts": {
    "start": "expo start",
    "android": "export JAVA_HOME=$(/usr/libexec/java_home -v 17) && expo run:android",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!.*((jest-)?react-native|@react-native|expo|@expo|react-navigation|@react-navigation|@unimodules|unimodules|react-native-svg|firebase))"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^firebase/auth$": "<rootDir>/node_modules/firebase/auth/dist/index.cjs.js",
      "^@firebase/util$": "<rootDir>/node_modules/@firebase/util/dist/index.node.cjs.js"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/packages/shared/"
    ]
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@homeoremedica/shared": "*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@react-navigation/native": "^7.1.8",
    "expo": "~57.0.8",
    "expo-asset": "~12.0.13",
    "expo-constants": "~18.0.12",
    "expo-dev-client": "~6.0.20",
    "expo-font": "~57.0.0",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.21",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~57.0.0",
    "firebase": "^12.9.0",
    "lottie-react-native": "~7.3.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-reanimated": "~4.5.1",
    "react-native-safe-area-context": "~5.8.0",
    "react-native-screens": "~4.26.0",
    "react-native-svg": "15.15.5",
    "react-native-svg-transformer": "^1.5.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@firebase/util": "^1.15.1",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.17",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "19.2.7",
    "ts-jest": "29",
    "typescript": "~5.9.2"
  },
  "private": true,
  "allowScripts": {
    "@firebase/util@1.15.1": true,
    "protobufjs@7.6.5": true,
    "fsevents@2.3.3": true
  }
}
